# Coverage exclusions — regex patterns matched against lines of the
# raw `go test -coverprofile` output, applied before the 100% gate
# by covgate (https://github.com/kfet/covgate).
#
# Convention: file-level patterns only. NO LINE NUMBERS. NO
# PER-FUNCTION REGEXES. Line numbers shift on any edit above them;
# per-function regexes mask new untested code added inside the same
# function. Anything coarser — a whole file, a whole subpackage, a
# whole generated bundle — is fine.
#
# See AGENTS.md "Coverage" for the rationale.

# Entry-point shims: cmd/<binary>/main.go.
# main() should be bare flag parsing, signal handling, and dependency
# assembly. Anything testable belongs in internal/*.
^github.com/kfet/slack-acp/cmd/[^/]+/main\.go:

# Per-package "unreachable.go" files. NOTE: this is a legacy pattern
# kept until the existing internal/acpclient/unreachable.go is
# refactored away; new exclusions should target the file the code
# naturally lives in, not a dedicated "unreachable.go" dumping
# ground (same shape as a utils.go grab-bag).
/unreachable\.go:
